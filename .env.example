# --- Serveur (Prisma / Neon) — ne jamais préfixer par VITE_ ---
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"
# Mettez des guillemets si le secret contient & # ou espaces
JWT_SECRET="remplacez_par_une_chaine_longue_aleatoire"

# Brevo (e-mails transactionnels + annonces) — https://app.brevo.com/settings/keys/api
BREVO_API_KEY=""
BREVO_SENDER_EMAIL="noreply@votredomaine.com"
BREVO_SENDER_NAME="La Forge Hub"
# Optionnel : reçoit une copie quand un webinaire est créé
BREVO_ADMIN_EMAIL=""
# URL publique du site (liens dans les e-mails) — ex. https://votredomaine.com
APP_PUBLIC_URL=""

# Admin : rôle dans la table `users` (enum learner | admin), pas via .env.
# Ex. : npm run admin:promote -- vous@exemple.com

# --- Frontend ---
VITE_USE_NEON_API=true
# URL publique du site (sans slash final) — canonical & Open Graph en prod. Ex. : https://votredomaine.com
# VITE_SITE_URL=https://votredomaine.com
# Même origine en dev : npm run dev (un seul serveur). Laisser vide.
# VITE_API_BASE_URL=

# Optionnel : si le port par défaut est pris, essayer 5174, 5175… (déconseillé : risque de confusion avec le navigateur)
# DEV_PORT_FALLBACK=1
